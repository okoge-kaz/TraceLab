---
// Shared contribute dialog: a consent modal followed by a result dialog (upload progress →
// accepted / rejected). Rendered ONCE on the page; both the Analyze surface and the Contributed
// pool entry point drive it via `requestContribution(file)` in src/lib/contribute-ui.ts.
import { useTranslations } from '../i18n';

const t = useTranslations(Astro.url).contributeDialog;
---

<div class="modal-overlay" id="cc-overlay" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="cc-title">
    <div class="m-ico" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="var(--terra)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"></path><path d="M9 12l2 2 4-4"></path></svg>
    </div>
    <h3 id="cc-title">{t.title}</h3>
    <p>{t.desc}</p>
    <ul>
      {t.bullets.map((item) => <li>{item}</li>)}
    </ul>
    <div class="modal-actions">
      <button class="btn btn-ghost" id="cc-cancel">{t.cancel}</button>
      <button class="btn btn-primary" id="cc-confirm">{t.confirm}</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="cr-overlay" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="cr-title">
    <div class="m-ico" id="cr-ico" aria-hidden="true"><span class="spinner"></span></div>
    <h3 id="cr-title">{t.uploading}</h3>
    <p id="cr-body">{t.uploadingBody}</p>
    <div class="result-progress" id="cr-progress" hidden>
      <div class="rp-bar"><i id="cr-fill"></i></div>
      <div class="rp-meta"><span id="cr-pct">0%</span><span id="cr-speed"></span></div>
    </div>
    <div class="modal-actions">
      <button class="btn btn-primary" id="cr-ok" hidden>{t.done}</button>
    </div>
  </div>
</div>

<script>
  import { initContributeDialog } from '../lib/contribute-ui';
  initContributeDialog();
</script>
